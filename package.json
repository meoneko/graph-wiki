{
  "name": "code-review-graph",
  "version": "0.1.0",
  "description": "Local-first code intelligence graph for code review and impact analysis",
  "type": "module",
  "bin": {
    "crg": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "crg": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "serve:mcp": "tsx src/mcp/server.ts",
    "test": "vitest run --exclude \"knowledge/**\" --exclude \"dist/**\" --exclude \"packages/**\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.4.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "fast-glob": "^3.3.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-c-sharp": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/chokidar": "^2.1.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
